# PATCTC Generator Environment Variables
PORT=3000
NODE_ENV=development

# JWT Secret — MUST change in production
JWT_SECRET=your-jwt-secret-change-in-production

# Supabase — required for database access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional fallback only if you intentionally run server queries with anon access
SUPABASE_ANON_KEY=

# Supabase Realtime — anon key is intentionally client-side (WebSocket subscriptions only).
# Mirror the values from SUPABASE_URL / SUPABASE_ANON_KEY above.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini API key for client-side AI features (intentionally VITE_-prefixed = bundled into frontend)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Google Safe Browsing API — server-only, used to scan post URLs for threats
GOOGLE_SAFE_BROWSING_KEY=your-safe-browsing-api-key

# Cloudflare R2 — server-only, presigned upload URLs for media
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=patctc-media
R2_PUBLIC_URL=https://pub-your-account-id.r2.dev

# Local upload directory for landing page media (default: ./uploads)
PATCTC_UPLOAD_ROOT=

# Seed default admin/user accounts on startup
# In non-production: auto-enabled unless set to 'false'
# In production: only seeds when set to 'true'
SEED_DEFAULT_USERS=true
